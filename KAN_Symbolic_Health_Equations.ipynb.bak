    "                \"#e67e22\", \"#2980b9\", \"#8e44ad\", \"#d35400\"]\n",
    "bars = ax.bar(score_labels, score_aucs, color=colors_p3, alpha=0.85, edgecolor=\"grey\")\n",
    "ax.set_ylabel(\"AUC (%)\", fontsize=10)\n",
    "ax.set_title(\"Abl. 3: Scoring Method (W=1000)\", fontsize=11)\n",
    "ax.set_ylim(50, 105)\n",
